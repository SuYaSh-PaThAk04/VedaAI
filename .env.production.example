# Copy to .env for docker compose, or set in your hosting dashboard (Render, Railway, VPS).

# Public URL of the Next.js app (no trailing slash)
WEB_URL=https://veda-ai-web-nu.vercel.app
# Optional local dev: WEB_URL=https://veda-ai-web-nu.vercel.app,http://localhost:3000

# Public URL of the API (used by browser + Next build)
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vedaai?retryWrites=true&w=majority

# Upstash / Redis Cloud URL (must support BullMQ pub/sub)
REDIS_URL=rediss://default:password@host:6379

# Gemini
GEMINI_API_KEY=your_key
GEMINI_MODEL=gemini-2.5-flash
MOCK_AI=false
